# binance-smart-money-oi-monitor
# Copy to .env and uncomment only what you need. Never commit real tokens.

# Shared local database. Use one absolute path for tracker, dashboard, and MCP.
# SMART_MONEY_DB_PATH=/absolute/path/to/snapshots.db

# Tracker universe and cadence (interval default 0 = one sweep then exit)
# SMART_MONEY_WATCHLIST=BTC,ETH,SOL
# SMART_MONEY_WATCHLIST_FILE=watchlist.json
# SMART_MONEY_INTERVAL_MIN=15

# Smart Money pool / sharding (0 pool = unlimited; shard index is zero-based)
# SMART_MONEY_POOL_MAX=200
# SMART_MONEY_SHARD_INDEX=0
# SMART_MONEY_SHARD_TOTAL=1

# Top Trader pool / sharding
# TOP_TRADER_POOL_MAX=200
# TOP_TRADER_SHARD_INDEX=0
# TOP_TRADER_SHARD_TOTAL=1

# Open Interest pool / sharding
# OI_POOL_MAX=200
# OI_SHARD_INDEX=0
# OI_SHARD_TOTAL=1

# Dashboard (localhost-only by default; PORT is a legacy fallback)
# SMART_MONEY_DASHBOARD_HOST=127.0.0.1
# SMART_MONEY_DASHBOARD_PORT=3001
# SMART_MONEY_DASHBOARD_CORS=https://your-frontend.example
# PORT=3001

# Share-card language: zh (default) or en
# SMART_MONEY_CARD_LANG=zh

# Optional Telegram alerts (disabled unless both token and chat ID are set)
# SMART_MONEY_ALERT_TG_TOKEN=123456:replace_me
# SMART_MONEY_ALERT_TG_CHAT_ID=-1001234567890
# SMART_MONEY_ALERT_WINDOW_MIN=30
# SMART_MONEY_ALERT_QTY_PCT=5

# Optional outbound proxy. proxy-from-env also honors NO_PROXY.
# HTTPS_PROXY=http://127.0.0.1:1082
# HTTP_PROXY=http://127.0.0.1:1082
# NO_PROXY=127.0.0.1,localhost
