# ============================================================
#  Easiest path: don't hand-fill the vars below — just run
#  `python setup.py`, which connects Telegram, auto-discovers
#  your chat_id, and writes this .env for you.
#  懒人首选:别手填下面这些，运行  python setup.py  一键配置。
#  向导会引导你连接 Telegram、自动抓取 chat_id、写好 .env。
# ============================================================

# ---- Telegram (required / 必填) ----
# EN: 1. Create a bot with @BotFather, get its token
#     2. Add the bot to your group/channel and make it an admin
#     3. CHAT_ID: DM @userinfobot for yours; groups use a negative id (@getidsbot)
#        (or just run `python setup.py` to grab it automatically — no third-party bot)
# 中文: 1. 找 @BotFather 创建 bot，拿到 token
#       2. 把 bot 拉进你的群/频道，给管理员权限
#       3. CHAT_ID：私聊找 @userinfobot 拿；群组用负数 id（找 @getidsbot）
#          （或直接用 python setup.py 自动获取，无需第三方 bot）
TG_BOT_TOKEN=          # EN: bot token from @BotFather · 中文: @BotFather 给的 bot token
TG_CHAT_ID=            # EN: target chat id (negative for groups) · 中文: 目标会话 id（群组为负数）

# ---- 价格触发阈值（百分比，可选，默认 ±3）----
PUMP_THRESHOLD=3.0
DUMP_THRESHOLD=-3.0

# ---- OI 异动阈值（百分比，可选；0=关闭该窗口）----
OI_SURGE_PCT_1M=3.0      # ~1分钟 OI 变化 ≥ 此值就告警
OI_SURGE_PCT_5M=6.0      # ~5分钟 OI 变化 ≥ 此值就告警

# ---- 爆量阈值（可选；倍数 0=关闭）----
VOL_BURST_MULT=5.0          # 收盘1m成交额 ≥ MULT × 近 N 根中位 => 爆量
VOL_BURST_LOOKBACK=20       # 计算基线用的历史根数
VOL_BURST_MIN_USDT=50000    # 低于此绝对成交额忽略（防小币噪音）

# ---- 防刷屏（可选）----
COOLDOWN_SEC=180

# ---- OI 轮询（可选）----
OI_POLL_SEC=60
OI_CONCURRENCY=15

# ---- 交易对列表刷新间隔（可选）----
SYMBOLS_REFRESH_SEC=3600

# ---- 命令权限 / 发送限速（可选）----
# 允许发命令的 chat id（逗号分隔），留空=只有 TG_CHAT_ID 能控制
ALLOWED_CHAT_IDS=
TG_MIN_SEND_INTERVAL=3.2  # 两条消息最小间隔秒，防撞 Telegram 限速

# ---- 多空比（可选）----
LSR_PERIOD=5m            # 多空比粒度：5m / 15m / 1h ...（币安最小 5m）

# ---- 运行时状态 / 历史持久化（可选）----
STATE_FILE=state.json
HISTORY_ENABLED=true     # 是否把每条告警存进 SQLite，供 /history /stats 复盘
DB_FILE=alerts.db
